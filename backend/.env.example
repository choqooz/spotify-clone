# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/spotify-clone

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ── Cloudinary (image / file uploads) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email of the user that gets admin privileges (must match a Clerk user's email)
ADMIN_EMAIL=admin@example.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (defaults to http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── YouTube / Download ────────────────────────────────────────────────────────
# Optional: path to a Netscape-format cookies file for authenticated YouTube requests
# On Render, use Secret Files at /etc/secrets/yt-cookies.txt
# Leave unset to skip cookie-based auth
YOUTUBE_COOKIES_PATH=/etc/secrets/yt-cookies.txt

# ── Logging ───────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info
